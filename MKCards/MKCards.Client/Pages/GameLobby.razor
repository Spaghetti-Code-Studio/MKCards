@page "/game"
@using Microsoft.AspNetCore.SignalR.Client
@using MKCards.Common.Models
@using MKCards.Client.Services
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject PlayerHubConnection Connection
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Game Servers</PageTitle>

<div class="container">
	<div class="row">
		<div class="col-md-6">
			<div class="card">
				<div class="card-header">
					<h4>Create Game Server</h4>
				</div>
				<div class="card-body">
					@if (currentGameServer == null)
					{
						<div class="mb-3">
							<label class="form-label">Your Name</label>
							<input @bind="playerName" class="form-control" placeholder="Enter your name" />
						</div>
						<div class="mb-3">
							<label class="form-label">Game Name</label>
							<input @bind="gameName" class="form-control" placeholder="Enter game name" />
						</div>
						<div class="mb-3">
							<label class="form-label">Max Players</label>
							<input @bind="maxPlayers" type="number" class="form-control" min="2" max="10" />
						</div>
						<div class="mb-3">
							<div class="m-1">
								<Switch @bind-Value="publicServer" Label="Public" />
							</div>
						</div>

						<button @onclick="CreateGameServer" class="btn btn-primary" disabled="@(!Connection.IsConnected || string.IsNullOrEmpty(playerName) || string.IsNullOrEmpty(gameName))">
							Create Game Server
						</button>
					}
					else
					{
						<div class="alert alert-success">
							<strong>Game Code: @currentGameServer.Id</strong>
							<br />
							Share this code with your friends!
						</div>
						<button @onclick="LeaveGameServer" class="btn btn-danger">Leave Game</button>
						@if (currentGameServer.CreatorConnectionId == Connection.Id && currentGameServer.State == GameServer.GameState.Waiting)
						{
							<button @onclick="StartGame" class="btn btn-success ms-2">Start Game</button>
						}
					}
				</div>
			</div>
		</div>

		<div class="col-md-6">
			<div class="card">
				<div class="card-header">
					<h4>Join Game Server</h4>
				</div>
				<div class="card-body">
					@if (currentGameServer == null)
					{
						<div class="mb-3">
							<label class="form-label">Your Name</label>
							<input @bind="joinPlayerName" class="form-control" placeholder="Enter your name" />
						</div>
						<div class="mb-3">
							<label class="form-label">Game Code</label>
							<input @bind="joinGameId" class="form-control" placeholder="Enter game code" />
						</div>
						<button @onclick="JoinGameServer" class="btn btn-primary" disabled="@(!Connection.IsConnected || string.IsNullOrEmpty(joinPlayerName) || string.IsNullOrEmpty(joinGameId))">
							Join Game Server
						</button>
					}
					else
					{
						<div class="alert alert-info">
							You are in game: @currentGameServer.Name
						</div>
					}
				</div>
			</div>
		</div>
	</div>

	@if (currentGameServer != null)
	{
		<div class="row mt-4">
			<div class="col-md-8">
				<div class="card">
					<div class="card-header">
						<h4>Game: @currentGameServer.Name (@currentGameServer.Id)</h4>
						<small>Status: @currentGameServer.State | Players: @currentGameServer.Players.Count/@currentGameServer.MaxPlayers</small>
					</div>
					<div class="card-body">
						<div class="mb-3">
							<strong>Players:</strong>
							<ul class="list-group">
								@foreach (var player in currentGameServer.Players.Values)
								{
									<li class="list-group-item d-flex justify-content-between align-items-center">
										@player.Name
										@if (player.ConnectionId == currentGameServer.CreatorConnectionId)
										{
											<span class="badge bg-warning">Host</span>
										}
									</li>
								}
							</ul>
						</div>

						<div class="mb-3">
							<strong>Game Chat:</strong>
							<div class="border p-3 mb-2" style="height: 200px; overflow-y: auto;">
								@foreach (var msg in gameMessages)
								{
									<div class="mb-1">
										<strong>@msg.PlayerName:</strong> @msg.Message
										<small class="text-muted">(@msg.Timestamp.ToString("HH:mm:ss"))</small>
									</div>
								}
							</div>
							<div class="input-group">
								<input @bind="chatMessage" @onkeypress="@((e) => { if (e.Key == "Enter") SendMessage(); })" class="form-control" placeholder="Type a message..." />
								<button @onclick="SendMessage" class="btn btn-outline-secondary">Send</button>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card">
					<div class="card-header">
						<h5>Available Public Game Servers</h5>
					</div>
					<div class="card-body">
						@if (gameServers.Any())
						{
							@foreach (var server in gameServers.Where(s => s.State == GameServer.GameState.Waiting))
							{
								<div class="card mb-2">
									<div class="card-body py-2">
										<h6 class="card-title mb-1">@server.Name</h6>
										<small class="text-muted">
											Code: @server.Id | Players: @server.Players.Count/@server.MaxPlayers
										</small>
									</div>
								</div>
							}
						}
						else
						{
							<p class="text-muted">No game servers available</p>
						}
					</div>
				</div>
			</div>
		</div>
	}
	else
	{
		<div class="row mt-4">
			<div class="col-12">
				<div class="card">
					<div class="card-header">
						<h5>Available Public Game Servers</h5>
					</div>
					<div class="card-body">
						@if (gameServers.Any())
						{
							<div class="row">
								@foreach (var server in gameServers.Where(s => s.State == GameServer.GameState.Waiting))
								{
									<div class="col-md-4 mb-3">
										<div class="card">
											<div class="card-body">
												<h6 class="card-title">@server.Name</h6>
												<p class="card-text">
													<strong>Code:</strong> @server.Id<br />
													<strong>Players:</strong> @server.Players.Count/@server.MaxPlayers<br />
													<strong>Status:</strong> @server.State
												</p>
											</div>
										</div>
									</div>
								}
							</div>
						}
						else
						{
							<p class="text-muted">No game servers available</p>
						}
					</div>
				</div>
			</div>
		</div>
	}
</div>

<div class="mt-3">
	<p>Connection status: <span class="@(Connection.IsConnected ? "text-success" : "text-danger")">@(Connection.IsConnected ? "Connected" : "Disconnected")</span></p>
	<p>ConnectionID: @Connection.Id</p>
</div>

@code {
	private List<GameServer> gameServers = new();
	private GameServer? currentGameServer;
	private List<GameMessage> gameMessages = new();

	private string playerName = "";
	private string gameName = "";
	private int maxPlayers = 4;

	private string joinPlayerName = "";
	private string joinGameId = "";

	private string chatMessage = "";

	private bool publicServer = false;

	protected override async Task OnInitializedAsync()
	{
		Connection.RegisterHandler<GameServerResponse>("GameCreated", OnGameCreated);
		Connection.RegisterHandler<GameServerResponse>("GameJoined", OnGameJoined);
		Connection.RegisterHandler<PlayerJoinedResponse>("PlayerJoined", OnPlayerJoined);
		Connection.RegisterHandler<PlayerLeftResponse>("PlayerLeft", OnPlayerLeft);
		Connection.RegisterHandler<MessageSentResponse>("GameMessage", OnGameMessage);
		Connection.RegisterHandler<GameStartedResponse>("GameStarted", OnGameStarted);
		Connection.RegisterHandler<List<GameServer>>("GameServerListUpdated", OnGameServerListUpdated);
		Connection.RegisterHandler<string>("Error", OnError);

		await LoadGameServers();
	}

	private async Task CreateGameServer()
	{
		var request = new CreateGameRequest
			{
				GameName = gameName.Trim(),
				PlayerName = playerName.Trim(),
				MaxPlayers = maxPlayers,
				Visibility = (publicServer ? GameServer.GameServerVisibility.Public : GameServer.GameServerVisibility.Private) 
			};

		await Connection.SendMessageAsync("CreateGameServer", request);
	}

	private async Task JoinGameServer()
	{
		var request = new JoinGameRequest
			{
				GameId = joinGameId.ToUpper().Trim(),
				PlayerName = joinPlayerName
			};

		await Connection.SendMessageAsync("JoinGameServer", request);
		await InvokeAsync(StateHasChanged);
	}

	private async Task LeaveGameServer()
	{
		await Connection.SendMessageAsync("LeaveGameServer");
		currentGameServer = null;
		gameMessages.Clear();
		await InvokeAsync(StateHasChanged);
	}

	private async Task StartGame()
	{
		await Connection.SendMessageAsync("StartGame");
	}

	private async Task SendMessage()
	{
		if (!string.IsNullOrEmpty(chatMessage))
		{
			chatMessage = chatMessage.Trim();
			await Connection.SendMessageAsync("SendMessageToGame", chatMessage);
			chatMessage = "";
			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task LoadGameServers()
	{
		await Connection.SendMessageAsync("GetGameServerList");
		await InvokeAsync(StateHasChanged);
	}

	private async Task OnGameCreated(GameServerResponse response)
	{
		if (response.Success)
		{
			currentGameServer = response.GameServer;
			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task OnGameJoined(GameServerResponse response)
	{
		if (response.Success)
		{
			currentGameServer = response.GameServer;
			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task OnPlayerJoined(PlayerJoinedResponse response)
	{
		if (response.Success)
		{
			currentGameServer = response.GameServer;
			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task OnPlayerLeft(PlayerLeftResponse response)
	{
		if (response.Success)
		{
			currentGameServer = response.GameServer;
			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task OnGameMessage(MessageSentResponse response)
	{
		if (response.Success)
		{
			var message = new GameMessage
				{
					PlayerName = response.PlayerName.Trim(),
					Message = response.Message.Trim(),
					Timestamp = response.TimeStamp
				};

			gameMessages.Add(message);
			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task OnGameStarted(GameStartedResponse response)
	{
		if (response.Success)
		{
			var currentGameServer = response.GameServer;
			await InvokeAsync(StateHasChanged);

			string gameName = "counter";
			Navigation.NavigateTo($"/game/{gameName}");
		}
	}

	private async Task OnGameServerListUpdated(List<GameServer> servers)
	{
		gameServers = servers.Where(server => server.Visibility == GameServer.GameServerVisibility.Public).ToList();
		await InvokeAsync(StateHasChanged);
	}

	private async Task OnError(string message)
	{
		await JSRuntime.InvokeVoidAsync("alert", message);
	}

	public async ValueTask DisposeAsync() { }

	public class GameMessage
	{
		public string PlayerName { get; set; } = "";
		public string Message { get; set; } = "";
		public DateTime Timestamp { get; set; }
	}
}
@* Components/Pages/Game.razor *@
@page "/game"
@using Microsoft.AspNetCore.SignalR.Client
@using MKCards.Common.Models
@using MKCards.Client.Services
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject PlayerHubConnection Connection
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Game Servers</PageTitle>

<div class="container">
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Create Game Server</h4>
                </div>
                <div class="card-body">
                    @if (currentGameServer == null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Your Name</label>
                            <input @bind="playerName" class="form-control" placeholder="Enter your name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Game Name</label>
                            <input @bind="gameName" class="form-control" placeholder="Enter game name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Max Players</label>
                            <input @bind="maxPlayers" type="number" class="form-control" min="2" max="10" />
                        </div>
                        <button @onclick="CreateGameServer" class="btn btn-primary" disabled="@(!IsConnected || string.IsNullOrEmpty(playerName) || string.IsNullOrEmpty(gameName))">
                            Create Game Server
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-success">
                            <strong>Game Code: @currentGameServer.Id</strong>
                            <br />
                            Share this code with your friends!
                        </div>
                        <button @onclick="LeaveGameServer" class="btn btn-danger">Leave Game</button>
                        @if (currentGameServer.CreatorConnectionId == GetConnectionId() && currentGameServer.State == GameState.Waiting)
                        {
                            <button @onclick="StartGame" class="btn btn-success ms-2">Start Game</button>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h4>Join Game Server</h4>
                </div>
                <div class="card-body">
                    @if (currentGameServer == null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Your Name</label>
                            <input @bind="joinPlayerName" class="form-control" placeholder="Enter your name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Game Code</label>
                            <input @bind="joinGameId" class="form-control" placeholder="Enter game code" />
                        </div>
                        <button @onclick="JoinGameServer" class="btn btn-primary" disabled="@(!IsConnected || string.IsNullOrEmpty(joinPlayerName) || string.IsNullOrEmpty(joinGameId))">
                            Join Game Server
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            You are in game: @currentGameServer.Name
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (currentGameServer != null)
    {
        <div class="row mt-4">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h4>Game: @currentGameServer.Name (@currentGameServer.Id)</h4>
                        <small>Status: @currentGameServer.State | Players: @currentGameServer.Players.Count/@currentGameServer.MaxPlayers</small>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <strong>Players:</strong>
                            <ul class="list-group">
                                @foreach (var player in currentGameServer.Players.Values)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        @player.Name
                                        @if (player.ConnectionId == currentGameServer.CreatorConnectionId)
                                        {
                                            <span class="badge bg-warning">Host</span>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>

                        <div class="mb-3">
                            <strong>Game Chat:</strong>
                            <div class="border p-3 mb-2" style="height: 200px; overflow-y: auto;">
                                @foreach (var msg in gameMessages)
                                {
                                    <div class="mb-1">
                                        <strong>@msg.PlayerName:</strong> @msg.Message
                                        <small class="text-muted">(@msg.Timestamp.ToString("HH:mm:ss"))</small>
                                    </div>
                                }
                            </div>
                            <div class="input-group">
                                <input @bind="chatMessage" @onkeypress="@((e) => { if (e.Key == "Enter") SendMessage(); })" class="form-control" placeholder="Type a message..." />
                                <button @onclick="SendMessage" class="btn btn-outline-secondary">Send</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5>Available Game Servers</h5>
                    </div>
                    <div class="card-body">
                        @if (gameServers.Any())
                        {
                            @foreach (var server in gameServers.Where(s => s.State == GameState.Waiting))
                            {
                                <div class="card mb-2">
                                    <div class="card-body py-2">
                                        <h6 class="card-title mb-1">@server.Name</h6>
                                        <small class="text-muted">
                                            Code: @server.Id | Players: @server.Players.Count/@server.MaxPlayers
                                        </small>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted">No game servers available</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5>Available Game Servers</h5>
                    </div>
                    <div class="card-body">
                        @if (gameServers.Any())
                        {
                            <div class="row">
                                @foreach (var server in gameServers.Where(s => s.State == GameState.Waiting))
                                {
                                    <div class="col-md-4 mb-3">
                                        <div class="card">
                                            <div class="card-body">
                                                <h6 class="card-title">@server.Name</h6>
                                                <p class="card-text">
                                                    <strong>Code:</strong> @server.Id<br />
                                                    <strong>Players:</strong> @server.Players.Count/@server.MaxPlayers<br />
                                                    <strong>Status:</strong> @server.State
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No game servers available</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-3">
    <p>Connection status: <span class="@(IsConnected ? "text-success" : "text-danger")">@(IsConnected ? "Connected" : "Disconnected")</span></p>
    <p>ConnectionID: @Connection.HubConnection.ConnectionId</p>
</div>

@code {
    // private HubConnection? hubConnection;
    private List<GameServer> gameServers = new();
    private GameServer? currentGameServer;
    private List<GameMessage> gameMessages = new();

    // Create game form
    private string playerName = "";
    private string gameName = "";
    private int maxPlayers = 4;

    // Join game form
    private string joinPlayerName = "";
    private string joinGameId = "";

    // Chat
    private string chatMessage = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // hubConnection = new HubConnectionBuilder()
            //     .WithUrl(Navigation.ToAbsoluteUri("/gamehub"))
            //     .WithAutomaticReconnect()
            //     .ConfigureLogging(logging =>
            //     {
            //         logging.SetMinimumLevel(LogLevel.Information);
            //     })
            //     .Build();

            Connection.HubConnection.On<GameServerResponse>("GameCreated", OnGameCreated);
            Connection.HubConnection.On<GameServerResponse>("GameJoined", OnGameJoined);
            Connection.HubConnection.On<PlayerJoinedResponse>("PlayerJoined", OnPlayerJoined);
            Connection.HubConnection.On<PlayerLeaveResponse>("PlayerLeft", OnPlayerLeft);
            Connection.HubConnection.On<SendMessageResponse>("GameMessage", OnGameMessage);
            Connection.HubConnection.On<StartGameResponse>("GameStarted", OnGameStarted);
            Connection.HubConnection.On<List<GameServer>>("GameServerListUpdated", OnGameServerListUpdated);
            Connection.HubConnection.On<string>("Error", OnError);

            // await hubConnection.StartAsync();
            await LoadGameServers();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("console.error", "SignalR connection failed: " + ex.Message);
        }
    }

    private async Task CreateGameServer()
    {
        if (Connection.HubConnection is not null)
        {
            var request = new CreateGameRequest
                {
                    GameName = gameName,
                    PlayerName = playerName,
                    MaxPlayers = maxPlayers
                };

            await Connection.HubConnection.SendAsync("CreateGameServer", request);
        }
    }

    private async Task JoinGameServer()
    {
        if (Connection.HubConnection is not null)
        {
            var request = new JoinGameRequest
                {
                    GameId = joinGameId.ToUpper(),
                    PlayerName = joinPlayerName
                };

            await Connection.HubConnection.SendAsync("JoinGameServer", request);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LeaveGameServer()
    {
        // await JSRuntime!.InvokeVoidAsync("alert", "Hello world!");

        if (Connection.HubConnection is not null)
        {
            await Connection.HubConnection.SendAsync("LeaveGameServer");
            currentGameServer = null;
            gameMessages.Clear();
            StateHasChanged();
        }
    }

    private async Task StartGame()
    {
        if (Connection.HubConnection is not null)
        {
            await Connection.HubConnection.SendAsync("StartGame");
        }
    }

    private async Task SendMessage()
    {
        if (Connection.HubConnection is not null && !string.IsNullOrEmpty(chatMessage))
        {
            await Connection.HubConnection.SendAsync("SendMessageToGame", chatMessage);
            chatMessage = "";
        }
    }

    private async Task LoadGameServers()
    {
        if (Connection.HubConnection is not null)
        {
            await Connection.HubConnection.SendAsync("GetGameServerList");
        }
    }

    private async Task OnGameCreated(GameServerResponse response)
    {
        if (response.Success)
        {
            currentGameServer = response.GameServer;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnGameJoined(GameServerResponse response)
    {
        if (response.Success)
        {
            currentGameServer = response.GameServer;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnPlayerJoined(PlayerJoinedResponse response)
    {
        if (response.Success)
        {
            currentGameServer = response.GameServer;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnPlayerLeft(PlayerLeaveResponse response)
    {
        if (response.Success)
        {
            currentGameServer = response.GameServer;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnGameMessage(SendMessageResponse data)
    {
        //
        var message = new GameMessage
            {
                PlayerName = data.PlayerName,
                Message = data.Message,
                Timestamp = data.TimeStamp
            };

        gameMessages.Add(message);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnGameStarted(StartGameResponse response)
    {
        var currentGameServer = response.GameServer;
        await InvokeAsync(StateHasChanged);

        string gameName = "counter";
        Navigation.NavigateTo($"/game/{gameName}");
    }

    private async Task OnGameServerListUpdated(List<GameServer> servers)
    {
        gameServers = servers;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnError(string message)
    {
        await JSRuntime.InvokeVoidAsync("alert", message);
    }

    private string GetConnectionId()
    {
        return Connection.HubConnection?.ConnectionId ?? "";
    }

    public bool IsConnected =>
        Connection.HubConnection?.State == HubConnectionState.Connected;

    public async ValueTask DisposeAsync()
    {
        //await JSRuntime.InvokeVoidAsync("console.log", "Disposing Game.razor");
        // if (Connection.HubConnection is not null)
        // {
        //     await Connection.HubConnection.DisposeAsync();
        // }
    }

    public class GameMessage
    {
        public string PlayerName { get; set; } = "";
        public string Message { get; set; } = "";
        public DateTime Timestamp { get; set; }
    }
}
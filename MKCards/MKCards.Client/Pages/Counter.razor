@page "/game/counter"
@using Microsoft.AspNetCore.SignalR.Client
@using MKCards.Common.Models;
@using MKCards.Client.Services
@inject PlayerHubConnection Connection
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>
<p role="status">Current count: @counter</p>
<button class="btn btn-primary" @onclick="IncrementCounter">+1</button>

<div class="mt-3">
    <p>Connection status: <span class="@(Connection.IsConnected ? "text-success" : "text-danger")">@(Connection.IsConnected ? "Connected" : "Disconnected")</span></p>
    <p>CoonectionID: @Connection.Id</p>
</div>

@code {
    private int counter = 0;

    protected override async Task OnInitializedAsync()
    {
        Connection.RegisterHandler("ChangeIncrement", () =>
        {
            counter++;
            StateHasChanged();
        });
    }

    private async Task IncrementCounter()
    {
        await Connection.SendMessageAsync("IncrementCounter");
    }
}
